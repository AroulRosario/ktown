generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
}

// NextAuth required tables
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          Role      @default(USER)
  repPoints     Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts        Account[]
  sessions        Session[]
  orders          Order[]
  karaokeBookings KaraokeBooking[]
  communityPosts  CommunityPost[]
  cartItems       CartItem[]
}

enum Role {
  USER
  ADMIN
}

// Products (Merchandise)
model Product {
  id          String   @id @default(cuid())
  name        String
  description String   @db.Text
  price       Float
  image       String
  category    String
  stock       Int      @default(0)
  exclusive   Boolean  @default(false)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  orderItems OrderItem[]
  cartItems  CartItem[]
}

// Food Menu Items
model FoodItem {
  id          String   @id @default(cuid())
  name        String
  description String   @db.Text
  price       Float
  image       String
  category    String
  spicy       Boolean  @default(false)
  prepTime    Int      @default(15) // minutes
  stock       Int      @default(100)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  orderItems OrderItem[]
  cartItems  CartItem[]
}

// Orders
model Order {
  id          String      @id @default(cuid())
  userId      String
  status      OrderStatus @default(PENDING)
  totalAmount Float
  address     String?
  notes       String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  orderItems OrderItem[]
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String?
  foodId    String?
  quantity  Int
  price     Float

  order   Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id])
  food    FoodItem? @relation(fields: [foodId], references: [id])
}

enum OrderStatus {
  PENDING
  COOKING
  OUT_FOR_DELIVERY
  ARRIVED
  CANCELLED
}

// Cart
model CartItem {
  id        String   @id @default(cuid())
  userId    String
  productId String?
  foodId    String?
  quantity  Int      @default(1)
  createdAt DateTime @default(now())

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id])
  food    FoodItem? @relation(fields: [foodId], references: [id])
}

// Karaoke Rooms & Bookings
model KaraokeRoom {
  id       String  @id @default(cuid())
  name     String
  capacity String
  price    Float
  image    String
  active   Boolean @default(true)

  bookings KaraokeBooking[]
}

model KaraokeBooking {
  id        String         @id @default(cuid())
  userId    String
  roomId    String
  date      DateTime
  startTime String
  duration  Int            @default(1)
  status    BookingStatus  @default(PENDING)
  amount    Float
  createdAt DateTime       @default(now())

  user User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  room KaraokeRoom @relation(fields: [roomId], references: [id])
}

enum BookingStatus {
  PENDING
  APPROVED
  REJECTED
  COMPLETED
}

// Community
model CommunityPost {
  id        String   @id @default(cuid())
  userId    String
  content   String   @db.Text
  image     String?
  likes     Int      @default(0)
  createdAt DateTime @default(now())

  user     User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  comments PostComment[]
}

model PostComment {
  id        String        @id @default(cuid())
  postId    String
  userId    String
  content   String        @db.Text
  createdAt DateTime      @default(now())

  post CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
}
